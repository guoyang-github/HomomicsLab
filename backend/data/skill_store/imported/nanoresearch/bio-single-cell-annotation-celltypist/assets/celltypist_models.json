{
  "tool": "CellTypist",
  "version": "1.0.0",
  "description": "CellTypist pre-trained model catalog",
  "last_updated": "2026-03-18",
  "package": "celltypist",
  "installation": "pip install celltypist",
  "website": "https://www.celltypist.org",
  "models": [
    {
      "name": "Immune_All_Low.pkl",
      "description": "All immune cells, low resolution",
      "tissue": "Immune",
      "species": "human",
      "cell_types": 28,
      "cells_trained": "~300,000",
      "use_case": "General immune annotation, broad categories",
      "resolution": "Low",
      "examples": ["T cells", "B cells", "Monocytes", "DCs", "NK cells"]
    },
    {
      "name": "Immune_All_High.pkl",
      "description": "All immune cells, high resolution",
      "tissue": "Immune",
      "species": "human",
      "cell_types": 98,
      "cells_trained": "~300,000",
      "use_case": "Detailed immune subtypes, fine-grained annotation",
      "resolution": "High",
      "examples": ["CD4 naive", "CD4 TCM", "CD4 TEM", "Treg", "Th1", "Th2", "Th17"]
    },
    {
      "name": "Cells_Intestinal_Training.pkl",
      "description": "Intestinal cells",
      "tissue": "Intestine",
      "species": "human",
      "cell_types": 56,
      "cells_trained": "~100,000",
      "use_case": "Colon and small intestine epithelial cells",
      "resolution": "Medium-High",
      "examples": ["Enterocytes", "Goblet cells", "Paneth cells", "Tuft cells"]
    },
    {
      "name": "Cells_Lung_Airway_Training.pkl",
      "description": "Lung airway cells",
      "tissue": "Lung",
