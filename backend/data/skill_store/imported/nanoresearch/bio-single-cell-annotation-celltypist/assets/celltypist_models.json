    {
      "name": "NLP_Mouse_Immune.pkl",
      "description": "Mouse immune cells",
      "tissue": "Immune",
      "species": "mouse",
      "cell_types": 22,
      "cells_trained": "~150,000",
      "use_case": "Mouse immune system annotation",
      "resolution": "Medium",
      "examples": ["CD4 T cells", "CD8 T cells", "B cells", "Monocytes"]
    },
    {
      "name": "Developing_Mouse_Brain.pkl",
      "description": "Developing mouse brain",
      "tissue": "Brain",
      "species": "mouse",
      "cell_types": 45,
      "cells_trained": "~400,000",
      "use_case": "Mouse brain development",
      "resolution": "High",
      "examples": ["Neuroblasts", "Neurons", "Glia", "Progenitors"]
    },
    {
      "name": "Developing_Human_Brain.pkl",
      "description": "Developing human brain",
      "tissue": "Brain",
      "species": "human",
      "cell_types": 51,
      "cells_trained": "~600,000",
      "use_case": "Human brain development",
      "resolution": "High",
      "examples": ["Radial glia", "Excitatory neurons", "Inhibitory neurons", "OPC"]
    },
    {
      "name": "Adult_Mouse_OlfactoryBulb.pkl",
      "description": "Mouse olfactory bulb",
      "tissue": "Brain",
      "species": "mouse",
      "cell_types": 25,
      "cells_trained": "~50,000",
      "use_case": "Olfactory bulb annotation",
      "resolution": "Medium",
      "examples": ["Mitral cells", "Granule cells", "PG cells"]
    },
    {
      "name": "COVID19_Immune_Landscape.pkl",
      "description": "COVID-19 immune landscape",
      "tissue": "Immune",
      "species": "human",
      "cell_types": 42,
      "cells_trained": "~800,000",
      "use_case": "COVID-19 patient immune profiling",
