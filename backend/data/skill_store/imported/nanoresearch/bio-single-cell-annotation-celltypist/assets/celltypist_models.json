      "examples": ["Activated T cells", "Exhausted T cells", "Inflammatory monocytes"]
    },
    {
      "name": "Tabula_Sapiens.pkl",
      "description": "Tabula Sapiens reference",
      "tissue": "Pan-tissue",
      "species": "human",
      "cell_types": 150,
      "cells_trained": "~500,000",
      "use_case": "Cross-tissue general annotation",
      "resolution": "Medium",
      "examples": ["Tissue-specific epithelial", "Endothelial", "Immune"]
    }
