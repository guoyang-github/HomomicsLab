  "usage": {
    "list_models": "celltypist.models.models_description()",
    "download": "celltypist.models.download_models(model='Immune_All_Low.pkl')",
    "annotate": "predictions = celltypist.annotate(adata, model='Immune_All_Low.pkl', majority_voting=True)"
  },
  "notes": [
    "Models are automatically downloaded on first use",
    "Use majority_voting=True for cluster-level consensus",
    "Check conf_score for prediction confidence",
    "Low confidence predictions may need manual review"
  ]
}
