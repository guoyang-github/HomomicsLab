{
  "provider": "openrouter",
  "base_url": "https://openrouter.ai/api/v1",
  "auth_type": "bearer",
  "env_key_name": "OPENROUTER_API_KEY",
  "image_generation_model": "google/gemini-2.0-flash-exp:free",
  "image_review_model": "openai/gpt-4o",
  "quality_thresholds": {
    "journal": 8.5,
    "conference": 8.0,
    "poster": 7.0,
    "presentation": 6.5,
    "report": 7.5,
    "grant": 8.0,
    "thesis": 8.0,
    "preprint": 7.5,
    "default": 7.5
  },
  "request_timeout": 120,
  "max_iterations": 2,
  "_provider_examples": {
    "dashscope": {
      "provider": "dashscope",
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "auth_type": "bearer",
      "env_key_name": "DASHSCOPE_API_KEY",
      "image_generation_model": "qwen-vl-max",
      "image_review_model": "qwen-max"
    },
    "siliconflow": {
      "provider": "siliconflow",
      "base_url": "https://api.siliconflow.cn/v1",
      "auth_type": "bearer",
      "env_key_name": "SILICONFLOW_API_KEY",
      "image_generation_model": "Qwen/Qwen2.5-VL-72B-Instruct",
      "image_review_model": "deepseek-ai/DeepSeek-V3"
    },
    "zhipu": {
      "provider": "zhipu",
      "base_url": "https://open.bigmodel.cn/api/paas/v4",
      "auth_type": "bearer",
      "env_key_name": "ZHIPU_API_KEY",
      "image_generation_model": "glm-4v-plus",
      "image_review_model": "glm-4-plus"
    },
    "moonshot": {
      "provider": "moonshot",
      "base_url": "https://api.moonshot.cn/v1",
      "auth_type": "bearer",
      "env_key_name": "MOONSHOT_API_KEY",
      "image_generation_model": "kimi-k2",
      "image_review_model": "kimi-k2"
    },
    "minimax": {
      "provider": "minimax",
      "base_url": "https://api.minimax.chat/v1",
      "auth_type": "bearer",
      "env_key_name": "MINIMAX_API_KEY",
      "image_generation_model": "minimax-image-01",
      "image_review_model": "minimax-text-01"
    }
  }
}
