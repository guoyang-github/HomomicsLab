# =============================================================================
# HomomicsLab environment configuration template
# =============================================================================
# Copy this file to ``.env`` and adjust values as needed.
# All variables use the ``HOMOMICS_*`` prefix and are consumed by
# ``backend/homomics_lab/config.py`` (Pydantic Settings).
# Sensitive values should be provided via secrets management in production.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker (required for docker-compose.yml)
# -----------------------------------------------------------------------------
# Host Docker group ID so backend/worker containers can access the Docker socket
# without running as root. Obtain it with:
#   getent group docker | cut -d: -f3
DOCKER_GID=999

# -----------------------------------------------------------------------------
# Core application
# -----------------------------------------------------------------------------
# HOMOMICS_DEBUG=false
# HOMOMICS_PORT=8080
# HOMOMICS_HOST=0.0.0.0
# HOMOMICS_API_VERSION=v1
# HOMOMICS_OPENAPI_DOCS_ENABLED=true
# HOMOMICS_DATA_DIR=./data
# Canonical skill drop-in directory. Defaults to the project-root ``skills/``
# folder and is independent of the backend's working directory.
# HOMOMICS_SKILLS_DIR=./skills
# Comma-separated list of extra skill directories to load at startup. External
# skill repos are no longer auto-discovered; list them here explicitly.
# HOMOMICS_EXTERNAL_SKILLS_DIRS=./external_skills
# HOMOMICS_SKILL_SIBLING_DISCOVERY_ENABLED=false

# -----------------------------------------------------------------------------
# Frontend / backend separation
# -----------------------------------------------------------------------------
# When the frontend and backend run on different hosts (e.g. backend on a Linux
# server, frontend on a PC), set these so the frontend knows where to reach the
# backend and the backend accepts cross-origin requests.
#
# For non-Docker frontend builds, create frontend/public/config.json:
#   {"apiBaseUrl": "http://your-server:8080/api", "wsUrl": "ws://your-server:8080"}
#
# For the frontend Docker image, set HOMOMICS_API_BASE_URL/HOMOMICS_WS_URL and
# the container startup script will generate config.json automatically.
# HOMOMICS_API_BASE_URL=http://your-server:8080/api
# HOMOMICS_WS_URL=ws://your-server:8080
# HOMOMICS_CORS_ORIGINS=["http://your-pc:5173"]
# HOMOMICS_TRUSTED_HOSTS=your-server

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite (default, suitable for local development):
HOMOMICS_DATABASE_URL=sqlite+aiosqlite:///./homomics_lab.db
HOMOMICS_SESSION_STORE_URL=sqlite+aiosqlite:///./data/sessions.db

# PostgreSQL (recommended for production):
# HOMOMICS_DATABASE_URL=postgresql+asyncpg://homomics:homomics@postgres:5432/homics_lab
# HOMOMICS_SESSION_STORE_URL=postgresql+asyncpg://homomics:homomics@postgres:5432/homics_lab
# HOMOMICS_DATABASE_POOL_SIZE=5
# HOMOMICS_DATABASE_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Authentication and authorization
# -----------------------------------------------------------------------------
# Set to true in production. When false, all users are treated as "anonymous".
# HOMOMICS_AUTH_ENABLED=false

# JWT settings (required when auth_enabled=true and OIDC is not used)
# Generate a strong secret, e.g.:
#   openssl rand -hex 32
# HOMOMICS_JWT_SECRET_KEY=
# HOMOMICS_JWT_ALGORITHM=HS256
# HOMOMICS_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Single shared API key (fallback / bootstrap). Prefer JWT or OIDC for users.
# HOMOMICS_API_KEY=

# OIDC settings (optional)
# HOMOMICS_OIDC_DISCOVERY_URL=
# HOMOMICS_OIDC_CLIENT_ID=
# HOMOMICS_OIDC_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
# HOMOMICS_RATE_LIMIT_ENABLED=false
# HOMOMICS_RATE_LIMIT_BACKEND=memory
# HOMOMICS_RATE_LIMIT_REDIS_URL=redis://redis:6379/0
# HOMOMICS_RATE_LIMIT_TRUST_PROXY=false
# HOMOMICS_RATE_LIMIT_REQUESTS_PER_MINUTE=60
# HOMOMICS_RATE_LIMIT_UPLOAD_MAX_BYTES=1073741824
# HOMOMICS_MAX_UPLOAD_FILE_BYTES=1073741824

# -----------------------------------------------------------------------------
# LLM routing
# -----------------------------------------------------------------------------
# Supported providers: openai, deepseek, qwen, zhipu, moonshot, ollama, ...
# HOMOMICS_LLM_PROVIDER=openai
# HOMOMICS_LLM_MODEL=gpt-4o-mini
# Comma-separated fallback models used when the primary model fails.
# HOMOMICS_LLM_FALLBACK_MODELS=
# HOMOMICS_LLM_API_KEY=
# HOMOMICS_LLM_BASE_URL=

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
# HOMOMICS_EMBEDDING_PROVIDER=sentence_transformers
# HOMOMICS_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# HOMOMICS_EMBEDDING_API_KEY=
# HOMOMICS_EMBEDDING_BASE_URL=

# -----------------------------------------------------------------------------
# Memory / vector / graph backends
# -----------------------------------------------------------------------------
# HOMOMICS_VECTOR_STORE_BACKEND=qdrant
# HOMOMICS_VECTOR_STORE_URL=http://localhost:6333
# HOMOMICS_GRAPH_BACKEND=networkx
# HOMOMICS_GRAPH_STORE_URL=
# HOMOMICS_MEMORY_RERANKER_MODEL=
# HOMOMICS_LLM_MEMORY_EXTRACTION_ENABLED=false

# -----------------------------------------------------------------------------
# Object storage (local or S3/MinIO)
# -----------------------------------------------------------------------------
# HOMOMICS_STORAGE_BACKEND=local
# For S3/MinIO:
# HOMOMICS_STORAGE_BACKEND=s3
# HOMOMICS_STORAGE_S3_BUCKET=homomics
# HOMOMICS_STORAGE_S3_ENDPOINT_URL=http://localhost:9000
# HOMOMICS_STORAGE_S3_REGION=
# HOMOMICS_STORAGE_S3_ACCESS_KEY=homomics
# HOMOMICS_STORAGE_S3_SECRET_KEY=homomicslab
# HOMOMICS_STORAGE_S3_PUBLIC_URL_PREFIX=http://localhost:9000/homics

# -----------------------------------------------------------------------------
# DataStore / result artifacts
# -----------------------------------------------------------------------------
# DataStore persists non-JSON skill outputs. Zarr arrays and groups are
# auto-detected and stored as on-disk .zarr directories under results_dir.
# Pickle fallback is disabled by default for security; enable only in trusted
# environments.
# HOMOMICS_ALLOW_PICKLE_SERIALIZATION=false

# -----------------------------------------------------------------------------
# Job queue / workers
# -----------------------------------------------------------------------------
# HOMOMICS_QUEUE_BACKEND=memory
# HOMOMICS_REDIS_URL=redis://localhost:6379/0
# HOMOMICS_WORKER_MODE=true
# HOMOMICS_WORKER_CONCURRENCY=1
# HOMOMICS_WORKER_HEARTBEAT_TTL=30
# HOMOMICS_WORKER_LOCK_TTL=600

# -----------------------------------------------------------------------------
# Skill sandbox and security
# -----------------------------------------------------------------------------
# HOMOMICS_SKILL_SANDBOX_BACKEND=auto
# HOMOMICS_SKILL_CONTAINER_IMAGE=python:3.12-slim
# HOMOMICS_R_CONTAINER_IMAGE=r-base:4.3.0
# HOMOMICS_SKILL_CONTAINER_MEMORY_MB=1024
# HOMOMICS_SKILL_CONTAINER_CPUS=1.0
# HOMOMICS_SKILL_CONTAINER_PIDS_LIMIT=64
# HOMOMICS_SKILL_CONTAINER_READONLY_ROOT=true
# HOMOMICS_SKILL_CONTAINER_VENV_MOUNT=true
# HOMOMICS_FORCE_SANDBOX=true
# HOMOMICS_AUTO_INSTALL_DEPENDENCIES=false
# HOMOMICS_INTERACTIVE_MODE=false
# HOMOMICS_SKILLS_SHELL_EXECUTION_ENABLED=false
# HOMOMICS_ALLOW_PICKLE_SERIALIZATION=false
# HOMOMICS_DOMAIN_STRICT_VALIDATION=false

# -----------------------------------------------------------------------------
# Workflow / Nextflow
# -----------------------------------------------------------------------------
# HOMOMICS_WORKFLOW_NEXTFLOW_ENABLED=true
# HOMOMICS_WORKFLOW_NEXTFLOW_MIN_PHASES=3
# Shared secret used to authenticate Nextflow weblog callbacks.
# Generate a strong secret and configure it in your Nextflow ``weblog`` setup.
# HOMOMICS_NEXTFLOW_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Scheduling / curation (optional background tasks)
# -----------------------------------------------------------------------------
# HOMOMICS_CURATION_ENABLED=false
# HOMOMICS_NARRATIVE_REPORT_ENABLED=false
# HOMOMICS_SOP_PROPOSAL_ENABLED=false
# HOMOMICS_EVOLUTION_ENABLED=false
# HOMOMICS_SCHEDULER_RUN_AT_STARTUP=false

# -----------------------------------------------------------------------------
# Budgets and caching
# -----------------------------------------------------------------------------
# HOMOMICS_MONTHLY_BUDGET_USD=
# HOMOMICS_MAX_LLM_COST_PER_REQUEST_USD=
# HOMOMICS_LLM_RESPONSE_CACHE_ENABLED=true
# HOMOMICS_LLM_RESPONSE_CACHE_BACKEND=local
# HOMOMICS_LLM_RESPONSE_CACHE_TTL_SECONDS=3600
# HOMOMICS_LLM_RESPONSE_CACHE_MAX_ENTRIES=1000

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# HOMOMICS_LOG_LEVEL=INFO
# HOMOMICS_LOG_JSON_FORMAT=true
# HOMOMICS_AUDIT_LOG_ENABLED=false
# HOMOMICS_AUDIT_LOG_PATH=./data/logs/audit.log
# HOMOMICS_OTEL_ENABLED=false
# HOMOMICS_OTEL_EXPORTER=console
# HOMOMICS_OTEL_OTLP_ENDPOINT=http://localhost:4317
# HOMOMICS_OTEL_SERVICE_NAME=homomicslab
# HOMOMICS_HEALTH_CHECK_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# Security headers / CORS
# -----------------------------------------------------------------------------
# HOMOMICS_CORS_ORIGINS=https://app.homomics.lab
# HOMOMICS_TRUSTED_HOSTS=app.homomics.lab

# -----------------------------------------------------------------------------
# Secrets manager
# -----------------------------------------------------------------------------
# HOMOMICS_SECRETS_DB_PATH=./data/secrets.db
# HOMOMICS_SECRETS_MASTER_KEY=
# HOMOMICS_SECRETS_PLAINTEXT_FALLBACK=false

# -----------------------------------------------------------------------------
# Context engine
# -----------------------------------------------------------------------------
# HOMOMICS_CONTEXT_ENGINE_MODEL=
# HOMOMICS_CONTEXT_TOKEN_BUDGET_MODE=normal
# HOMOMICS_CONTEXT_ENABLE_PROJECT_STATE=true
# HOMOMICS_CONTEXT_ENABLE_EPISODIC_SUMMARY=true
# HOMOMICS_CONTEXT_OUTPUT_RESERVE_TOKENS=2000

# -----------------------------------------------------------------------------
# Session / data retention
# -----------------------------------------------------------------------------
# HOMOMICS_SESSION_TTL_DAYS=90
# HOMOMICS_ENABLE_SEMANTIC_MEMORY=true
