# HomomicsLab environment configuration
# Copy this file to .env and adjust values for your deployment.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
HOMOMICS_DEBUG=false
HOMOMICS_APP_NAME=HomomicsLab
HOMOMICS_HOST=0.0.0.0
HOMOMICS_PORT=8080

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# For local development (single process):
HOMOMICS_DATABASE_URL=sqlite+aiosqlite:///./data/homics_lab.db

# For production with PostgreSQL:
# HOMOMICS_DATABASE_URL=postgresql+asyncpg://homomics:changeme@db:5432/homicslab

# Session store URL (defaults to ./data/sessions.db if unset)
HOMOMICS_SESSION_STORE_URL=sqlite+aiosqlite:///./data/sessions.db

# -----------------------------------------------------------------------------
# Security (enable in production)
# -----------------------------------------------------------------------------
# Set to true to require API key authentication on all routes.
HOMOMICS_AUTH_ENABLED=false
HOMOMICS_API_KEY=change-me-to-a-long-random-secret

# Force all code execution (shell_exec, CodeAct, skills) through an isolated
# sandbox (bubblewrap or container). Local sandbox is NOT sufficient for
# shell_exec when this is enabled.
HOMOMICS_FORCE_SANDBOX=true
HOMOMICS_SKILL_SANDBOX_BACKEND=auto

# Allow pickle serialization only in fully trusted single-user environments.
HOMOMICS_ALLOW_PICKLE_SERIALIZATION=false

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
HOMOMICS_RATE_LIMIT_ENABLED=false
HOMOMICS_RATE_LIMIT_REQUESTS_PER_MINUTE=60
HOMOMICS_MAX_UPLOAD_FILE_BYTES=1073741824

# -----------------------------------------------------------------------------
# CORS / trusted hosts (set explicitly for production)
# -----------------------------------------------------------------------------
# HOMOMICS_CORS_ORIGINS=["https://app.homomics.lab"]
# HOMOMICS_TRUSTED_HOSTS=["app.homomics.lab"]

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
HOMOMICS_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Per-request and monthly cost caps (USD). Requires auth enabled for enforcement.
HOMOMICS_MAX_LLM_COST_PER_REQUEST_USD=5.0
HOMOMICS_MONTHLY_BUDGET_USD=100.0

# -----------------------------------------------------------------------------
# Object storage (local by default; set to s3 for MinIO/S3/OSS)
# -----------------------------------------------------------------------------
HOMOMICS_STORAGE_BACKEND=local
# HOMOMICS_STORAGE_BACKEND=s3
# HOMOMICS_STORAGE_S3_BUCKET=homomicslab
# HOMOMICS_STORAGE_S3_ENDPOINT_URL=https://s3.amazonaws.com
# HOMOMICS_STORAGE_S3_REGION=us-east-1
# HOMOMICS_STORAGE_S3_ACCESS_KEY=...
# HOMOMICS_STORAGE_S3_SECRET_KEY=...
# HOMOMICS_STORAGE_S3_PUBLIC_URL_PREFIX=https://homomicslab.s3.amazonaws.com

# -----------------------------------------------------------------------------
# Audit logging
# -----------------------------------------------------------------------------
HOMOMICS_AUDIT_LOG_ENABLED=false
# HOMOMICS_AUDIT_LOG_PATH=/app/data/logs/audit.log

# -----------------------------------------------------------------------------
# nf-core integration
# -----------------------------------------------------------------------------
HOMOMICS_NFCORE_ENABLED=true
# HOMOMICS_NFCORE_CACHE_DIR=/app/data/nfcore_pipelines
HOMOMICS_NFCORE_DEFAULT_PROFILES=docker

# -----------------------------------------------------------------------------
# Job queue
# -----------------------------------------------------------------------------
HOMOMICS_QUEUE_BACKEND=redis
HOMOMICS_REDIS_URL=redis://redis:6379/0
HOMOMICS_WORKER_MODE=true
HOMOMICS_WORKER_CONCURRENCY=1

# -----------------------------------------------------------------------------
# Scheduled background tasks — disabled by default for individual users.
# Enable only if you understand the token/compute cost implications.
# -----------------------------------------------------------------------------
HOMOMICS_CURATION_ENABLED=false
HOMOMICS_NARRATIVE_REPORT_ENABLED=false
HOMOMICS_SOP_PROPOSAL_ENABLED=false
HOMOMICS_EVOLUTION_ENABLED=false

# -----------------------------------------------------------------------------
# External skills
# -----------------------------------------------------------------------------
# HOMOMICS_EXTERNAL_SKILLS_DIRS=/app/external_skills
